# Copy to `.env` and fill in. `.env` is gitignored.

# Required: Wise session bearer JWT (from your browser's Authorization header
# on api.wiseapp.live, or from an admin login). Expires periodically — refresh
# from the dashboard if you see 401s.
WISE_BEARER_TOKEN=

# Optional overrides (sensible defaults in onboard_tutors.py)
# WISE_INSTITUTE_ID=6a10430bf464d10720e4f6be
# EMAIL_DOMAIN=tutors.frogfluent.test
